{
  "name": "domvault-services",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Constellation registry + Observatory query services (zero runtime deps, zero telemetry)",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test $(find registry client observatory e2e constellation -name '*.test.ts' -not -path '*/node_modules/*')",
    "registry:dev": "tsx registry/server/main.ts",
    "observatory:dev": "tsx observatory/server/endpoint.ts",
    "demo": "tsx scripts/demo.ts",
    "publish": "tsx scripts/publish-frameworks.ts",
    "build:registry": "esbuild registry/server/main.ts --bundle --platform=node --format=esm --outfile=dist/registry.mjs",
    "start:registry": "node dist/registry.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.22.4",
    "typescript": "^5.6.0"
  }
}
